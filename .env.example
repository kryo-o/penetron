# Copy to .env and fill in. In production these come from UiPath Orchestrator Assets
# (Credential assets for secrets), injected as env vars on the runner.

# --- Target (NON-PRODUCTION ONLY) ---
PENETRON_TARGET_URL=http://localhost:4000
PENETRON_ENV=staging
# replay = deterministic committed scenarios (demo); regenerate = live generation
PENETRON_MODE=replay

# --- Jira (Atlassian REST v3) ---
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@your-org.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=SEC
# Atlassian accountId of the project manager the bug is assigned to
JIRA_PM_ACCOUNT_ID=

# --- Slack (incoming webhook) ---
SLACK_WEBHOOK_URL=

# --- UiPath Test Manager (S2S client) — Layer 2 result sync ---
# Org slug = hackathon26_879, tenant = DefaultTenant.
# Identity/token endpoint is HOST-LEVEL (no org/tenant in path):
UIPATH_IDENTITY_TOKEN_URL=https://staging.uipath.com/identity_/connect/token
# Test Manager API service root (tenant-scoped). API version is v2 (e.g. /api/v2/projects):
UIPATH_TM_BASE_URL=https://staging.uipath.com/hackathon26_879/DefaultTenant/testmanager_
# Gotchas (verified 2026-06-24): (1) parse this file LITERALLY — shell-sourcing corrupts
# secrets containing '$'.  (2) Cloudflare blocks default clients; send a browser User-Agent.
UIPATH_TM_CLIENT_ID=
UIPATH_TM_CLIENT_SECRET=
UIPATH_TM_PROJECT_ID=0ce976c4-99d8-0000-4ab9-0b49ce69b305

# --- Penetron MCP server (Remote MCP bridge for UiPath Agent Builder) ---
# Transport: stdio (default) or http. For the UiPath tunnel use http.
PENETRON_MCP_TRANSPORT=stdio
PENETRON_MCP_PORT=7337
# Bearer token required on the HTTP transport. Generate: openssl rand -hex 32
# In production this is an Orchestrator Credential Asset injected to the runner.
PENETRON_MCP_TOKEN=


