# Penetron — environment template. Copy to a .env at the REPO ROOT and fill in:
#     cp .env.example .env
# loadEnv reads the repo-root .env (and pentests/.env if present, as an override). Real
# env vars / UiPath Orchestrator Credential Assets always win. NEVER commit .env (git-ignored).
#
# What each group is for:
#   Core ............ local Layer 1/2 run — all optional (sensible defaults).
#   Test Manager .... required for LIVE red/green evidence sync (else `npm run tm:sync` dry-runs).
#   MCP server ...... required for the UiPath Agent Builder bridge (the agent path).
#   Slack / Jira .... optional integrations (dry-run without creds).
#   Trigger ......... optional; only for `npm run uipath:trigger` (classic StartJobs). The LIVE
#                     PR trigger uses the native UiPath GitHub connector and needs NONE of these.

# ── Core: local Layer 1/2 run (optional; sensible defaults) ──
PENETRON_TARGET_URL=http://localhost:4000
PENETRON_ENV=staging
# replay = deterministic committed scenarios (demo); regenerate = live generation
PENETRON_MODE=replay

# ── UiPath Test Manager (S2S client) — required for LIVE Layer 2 evidence sync ──
# Identity/token endpoint is HOST-LEVEL (no org/tenant in the path):
UIPATH_IDENTITY_TOKEN_URL=https://staging.uipath.com/identity_/connect/token
# Test Manager API service root (tenant-scoped), e.g. https://<host>/<org>/<tenant>/testmanager_
UIPATH_TM_BASE_URL=https://staging.uipath.com/<org>/<tenant>/testmanager_
UIPATH_TM_CLIENT_ID=
UIPATH_TM_CLIENT_SECRET=
UIPATH_TM_PROJECT_ID=
# Gotchas (verified): (1) this file is parsed LITERALLY — shell-sourcing corrupts secrets
# containing '$'.  (2) Cloudflare fronts staging.uipath.com and 403s default clients; the
# code sends a browser User-Agent.

# ── Remote MCP server (Remote MCP bridge for UiPath Agent Builder) ──
# Bearer for the HTTP transport (401 without it). Generate: openssl rand -hex 32
PENETRON_MCP_TOKEN=
# Your UiPath org id — the agenthub proxy sends it as the `accountid` header, which the
# server accepts for tools/call (method-scoped auth). Required for the cloud agent path.
PENETRON_MCP_ALLOWED_ACCOUNT=
# Transport: stdio (default) or http. For the UiPath tunnel use http.
PENETRON_MCP_TRANSPORT=stdio
PENETRON_MCP_PORT=7337

# ── Slack — optional (omit -> notify dry-runs) ──
SLACK_WEBHOOK_URL=

# ── Jira — optional (v2 prototype; `npm run jira`). Dry-runs without creds (Atlassian REST v3) ──
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@your-org.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=SEC
# Atlassian accountId of the project manager the bug is assigned to
JIRA_PM_ACCOUNT_ID=

# ── Optional: classic StartJobs PR trigger (`npm run uipath:trigger`) ──
# NOT needed for the live demo — the LIVE PR trigger is the native UiPath GitHub connector.
UIPATH_ORG_URL=https://staging.uipath.com/<org>/<tenant>
UIPATH_ORCH_CLIENT_ID=
UIPATH_ORCH_CLIENT_SECRET=
UIPATH_FOLDER_ID=
UIPATH_PROCESS_NAME=Penetron Security Gate
